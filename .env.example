SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ⚠️ DANGER: DO NOT EXPOSE THIS IN FRONTEND OR GIT
# This key allows bypassing RLS. Use ONLY in server-side logic (Edge Functions/API routes).
# SUPABASE_SERVICE_ROLE=

# Analytics & Marketing — only loaded when user grants consent via cookie banner
NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Push notifications widget. Default OFF: el endpoint /api/push/send tiene un
# bug (verifyInternalSecret no es llamable desde browser). Activar 'true'
# solo tras el sprint de fix.
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
