{
  "mcpServers": {
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com/mcp",
      "headers": {
        "Authorization": "Bearer ${VERCEL_TOKEN}"
      }
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "stitch": {
      "command": "npx",
      "args": [
        "stitch-mcp"
      ],
      "env": {
        "STITCH_API_KEY": "AQ.Ab8RN6K3PgbNsEbTb9EdL5wT_pTLEbYI6F3U4iLB5F065VA7vQ"
      }
    }
  }
}